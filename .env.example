# Variabile opzionale: cartella dove salvare i file Markdown.
# Default: <repo>/note_riunioni (relativa alla root del progetto).
# Decommenta e personalizza solo se vuoi salvarli altrove.
# OUTPUT_DIR=C:\percorso\personalizzato\note_riunioni

# Query di ricerca Gmail per filtrare le email con le note Gemini
# Esempi: "label:note-di-gemini", "subject:Note: newer_than:30d"
GMAIL_SEARCH=label:note-di-gemini

# Owner principale per la board Kanban personale (MeetWiki/MY-KANBAN.md)
# Default: persona piu' frequente nei partecipanti
MEETWIKI_OWNER=

# === Obsidian Copilot / GitHub Models (Fase A) =========================
# Personal Access Token (fine-grained) con scope "Models: read".
# Genera su: https://github.com/settings/personal-access-tokens
# Usato dal plugin "Copilot for Obsidian" come API key verso models.github.ai
# NB: tieni .env fuori dal repo (gia' in .gitignore).
GITHUB_MODELS_TOKEN=
# Modello di default consigliato (free tier Copilot Pro: 150 req/giorno):
GITHUB_MODELS_DEFAULT=openai/gpt-4o-mini
